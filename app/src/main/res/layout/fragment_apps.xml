<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg" android:padding="@dimen/spacing_xl">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="@string/app_rules_title" android:textSize="@dimen/text_title" android:textStyle="bold"
        android:textColor="@color/primary" android:fontFamily="sans-serif" android:layout_marginBottom="6dp"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="@string/app_rules_description"
        android:textSize="@dimen/text_caption" android:textColor="@color/text_section" android:fontFamily="sans-serif"
        android:layout_marginBottom="@dimen/spacing_md"/>
    <Button android:id="@+id/btn_load_apps" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="@string/load_installed_apps"
        style="@style/KyokanButton" android:layout_marginBottom="10dp"/>

    <!-- Search bar -->
    <EditText android:id="@+id/et_search" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="@string/search_apps"
        android:textSize="@dimen/text_body" android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
        android:background="@color/surface" android:padding="@dimen/spacing_md" android:fontFamily="sans-serif"
        android:inputType="text" android:layout_marginBottom="@dimen/spacing_sm"/>

    <!-- Select/Deselect All -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="10dp">
        <Button android:id="@+id/btn_select_all" android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:text="@string/select_all"
            style="@style/KyokanButton" android:textSize="@dimen/text_caption" android:layout_marginEnd="@dimen/spacing_xs"/>
        <Button android:id="@+id/btn_deselect_all" android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:text="@string/deselect_all"
            style="@style/KyokanButton.Danger" android:textSize="@dimen/text_caption" android:layout_marginStart="@dimen/spacing_xs"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/apps_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"/>
</LinearLayout>
