<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/bg">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="@dimen/spacing_xl">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_md_lg">
            <ImageView android:layout_width="@dimen/touch_target_min" android:layout_height="@dimen/touch_target_min"
                android:src="@drawable/logo_foreground" android:scaleType="centerCrop"
                android:layout_marginEnd="@dimen/spacing_md" android:contentDescription="@string/app_name"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/app_name" android:textSize="22sp" android:textStyle="bold"
                    android:textColor="@color/primary" android:fontFamily="sans-serif" android:letterSpacing="0.12"
                    android:textAllCaps="true"/>
                <TextView android:id="@+id/txt_version"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="@dimen/text_micro"
                    android:textColor="@color/text_dimmed" android:fontFamily="sans-serif"/>
            </LinearLayout>
        </LinearLayout>

        <!-- L15: Onboarding hint for new users -->
        <TextView android:id="@+id/txt_onboarding" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="@dimen/spacing_lg" android:background="@color/card_enabled_bg"
            android:fontFamily="sans-serif" android:textSize="@dimen/text_caption" android:textColor="@color/text_secondary"
            android:lineSpacingExtra="@dimen/spacing_xs" android:layout_marginBottom="@dimen/spacing_md"
            android:visibility="gone"
            android:text="@string/onboarding_welcome"/>

        <Button android:id="@+id/btn_setup" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:backgroundTint="@color/primary"
            android:textColor="@color/text_on_accent" android:fontFamily="sans-serif" android:layout_marginBottom="@dimen/spacing_xs"/>
        <TextView android:id="@+id/txt_setup_status" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="@dimen/spacing_md" android:background="@color/surface"
            android:fontFamily="sans-serif" android:textSize="@dimen/text_label" android:textColor="@color/text_muted"
            android:layout_marginBottom="@dimen/spacing_xl"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/section_master_switch" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@color/surface" android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_lg">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/enable_notification_reading"
                android:textColor="@color/text_primary" android:textSize="@dimen/text_body" android:fontFamily="sans-serif"/>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_enabled"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:contentDescription="@string/cd_master_switch"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/section_read_mode" style="@style/SectionLabel"/>
        <Spinner android:id="@+id/spinner_read_mode" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="@color/surface"
            android:padding="@dimen/spacing_md" android:layout_marginBottom="@dimen/spacing_sm"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@color/surface" android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_xl">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/always_read_app_name"
                android:textColor="@color/text_primary" android:textSize="@dimen/text_body" android:fontFamily="sans-serif"/>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_read_app_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/section_dnd" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@color/surface" android:padding="@dimen/spacing_lg">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/enable_quiet_hours"
                android:textColor="@color/text_primary" android:textSize="@dimen/text_body" android:fontFamily="sans-serif"/>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_dnd"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:contentDescription="@string/cd_dnd_toggle"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/layout_dnd" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:background="@color/surface" android:padding="@dimen/spacing_lg"
            android:layout_marginTop="3dp" android:visibility="gone">
            <TextView android:id="@+id/txt_dnd_start" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Silence from: 22:00"
                android:textColor="@color/text_secondary" android:fontFamily="sans-serif" android:textSize="@dimen/text_body_sm"
                android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_dnd_start" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:progressTint="@color/accent_dnd"
                android:thumbTint="@color/accent_dnd" android:layout_marginBottom="@dimen/spacing_md_lg"
                android:contentDescription="Silence start hour"/>
            <TextView android:id="@+id/txt_dnd_end" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Until: 08:00"
                android:textColor="@color/text_secondary" android:fontFamily="sans-serif" android:textSize="@dimen/text_body_sm"
                android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_dnd_end" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:progressTint="@color/accent_dnd"
                android:thumbTint="@color/accent_dnd"
                android:contentDescription="Silence end hour"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/section_listening" style="@style/SectionLabel" android:layout_marginTop="@dimen/spacing_xl"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@color/surface" android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/activate_listening"
                    android:textColor="@color/text_primary" android:textSize="@dimen/text_body" android:fontFamily="sans-serif"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/listening_description"
                    android:textColor="@color/text_subtitle" android:textSize="@dimen/text_caption" android:fontFamily="sans-serif"/>
            </LinearLayout>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_listening"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:contentDescription="@string/cd_listening_toggle"/>
        </LinearLayout>
        <TextView android:id="@+id/listening_status" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="@dimen/spacing_md" android:background="@color/surface"
            android:fontFamily="sans-serif" android:textSize="@dimen/text_label" android:textColor="@color/text_muted"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:text="@string/listening_off"/>

        <!-- L14: Theme toggle -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/section_theme" style="@style/SectionLabel" android:layout_marginTop="@dimen/spacing_xl"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@color/surface" android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_xl">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/theme_label"
                    android:textColor="@color/text_primary" android:textSize="@dimen/text_body" android:fontFamily="sans-serif"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/theme_description"
                    android:textColor="@color/text_subtitle" android:textSize="@dimen/text_caption" android:fontFamily="sans-serif"/>
            </LinearLayout>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_dark_mode"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Post-setup guidance (M22) -->
        <TextView android:id="@+id/txt_guidance" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="@dimen/spacing_lg" android:background="@color/surface"
            android:fontFamily="sans-serif" android:textSize="@dimen/text_caption" android:textColor="@color/text_section"
            android:visibility="gone"
            android:lineSpacingExtra="@dimen/spacing_xs"/>

        <!-- B-10: Data export/import -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/section_data" style="@style/SectionLabel" android:layout_marginTop="@dimen/spacing_xl"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center">
            <Button android:id="@+id/btn_export" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/export_data"
                style="@style/KyokanButton"
                android:layout_marginEnd="@dimen/spacing_sm"/>
            <Button android:id="@+id/btn_import" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/import_data"
                style="@style/KyokanButton"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
