<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#110d18">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="14dp">
            <ImageView android:layout_width="48dp" android:layout_height="48dp"
                android:src="@drawable/logo_foreground" android:scaleType="centerCrop"
                android:layout_marginEnd="12dp" android:contentDescription="Logo"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="KYŌKAN" android:textSize="22sp" android:textStyle="bold"
                    android:textColor="#b898d4" android:fontFamily="sans-serif" android:letterSpacing="0.12"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="v4.0  ·  Kokoro + Piper + Orpheus" android:textSize="10sp"
                    android:textColor="#7e6e98" android:fontFamily="sans-serif"/>
            </LinearLayout>
        </LinearLayout>

        <!-- L15: Onboarding hint for new users -->
        <TextView android:id="@+id/txt_onboarding" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="16dp" android:background="#1a1428"
            android:fontFamily="sans-serif" android:textSize="12sp" android:textColor="#b0a4c0"
            android:lineSpacingExtra="4dp" android:layout_marginBottom="12dp"
            android:visibility="gone"
            android:text="@string/onboarding_welcome"/>

        <Button android:id="@+id/btn_setup" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:backgroundTint="#b898d4"
            android:textColor="#0a0710" android:fontFamily="sans-serif" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/txt_setup_status" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="12dp" android:background="#181222"
            android:fontFamily="sans-serif" android:textSize="11sp" android:textColor="#8a7a9e"
            android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/section_master_switch" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#181222" android:padding="16dp"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/enable_notification_reading"
                android:textColor="#d4cce0" android:textSize="14sp" android:fontFamily="sans-serif"/>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_enabled"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/section_read_mode" style="@style/SectionLabel"/>
        <Spinner android:id="@+id/spinner_read_mode" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="#181222"
            android:padding="12dp" android:layout_marginBottom="8dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#181222" android:padding="16dp"
            android:layout_marginBottom="20dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/always_read_app_name"
                android:textColor="#d4cce0" android:textSize="14sp" android:fontFamily="sans-serif"/>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_read_app_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/section_dnd" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#181222" android:padding="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/enable_quiet_hours"
                android:textColor="#d4cce0" android:textSize="14sp" android:fontFamily="sans-serif"/>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_dnd"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/layout_dnd" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:background="#181222" android:padding="16dp"
            android:layout_marginTop="3dp" android:visibility="gone">
            <TextView android:id="@+id/txt_dnd_start" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Silence from: 22:00"
                android:textColor="#b0a4c0" android:fontFamily="sans-serif" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_dnd_start" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:progressTint="#ffaa00"
                android:thumbTint="#ffaa00" android:layout_marginBottom="14dp"
                android:contentDescription="Silence start hour"/>
            <TextView android:id="@+id/txt_dnd_end" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Until: 08:00"
                android:textColor="#b0a4c0" android:fontFamily="sans-serif" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_dnd_end" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:progressTint="#ffaa00"
                android:thumbTint="#ffaa00"
                android:contentDescription="Silence end hour"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/section_listening" style="@style/SectionLabel" android:layout_marginTop="20dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#181222" android:padding="16dp"
            android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/activate_listening"
                    android:textColor="#d4cce0" android:textSize="14sp" android:fontFamily="sans-serif"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/listening_description"
                    android:textColor="#7a6a8e" android:textSize="12sp" android:fontFamily="sans-serif"/>
            </LinearLayout>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_listening"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <TextView android:id="@+id/listening_status" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="12dp" android:background="#181222"
            android:fontFamily="sans-serif" android:textSize="11sp" android:textColor="#8a7a9e"
            android:layout_marginBottom="20dp"
            android:text="@string/listening_off"/>

        <!-- Post-setup guidance (M22) -->
        <TextView android:id="@+id/txt_guidance" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="16dp" android:background="#181222"
            android:fontFamily="sans-serif" android:textSize="12sp" android:textColor="#9b7eb8"
            android:visibility="gone"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>
</ScrollView>
