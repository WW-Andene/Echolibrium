<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/bg">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="KYŌKAN" android:textSize="22sp" android:textStyle="bold"
            android:textColor="@color/green" android:fontFamily="monospace" android:letterSpacing="0.12"
            android:layout_marginBottom="14dp"/>

        <TextView android:id="@+id/status_text" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="12dp" android:background="@color/surface"
            android:fontFamily="monospace" android:textSize="13sp" android:layout_marginBottom="4dp"/>

        <TextView android:id="@+id/service_status_text" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="12dp" android:background="@color/surface"
            android:fontFamily="monospace" android:textSize="12sp" android:textColor="@color/text_dim"
            android:layout_marginBottom="2dp"/>

        <TextView android:id="@+id/engine_status_text" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="12dp" android:background="@color/surface"
            android:fontFamily="monospace" android:textSize="11sp" android:textColor="@color/text_dim"
            android:layout_marginBottom="0dp"/>

        <ProgressBar android:id="@+id/engine_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="6dp"
            android:max="100" android:progress="0"
            android:progressTint="@color/green" android:progressBackgroundTint="#222222"
            android:background="@color/surface"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:layout_marginBottom="2dp"
            android:visibility="gone"/>

        <TextView android:id="@+id/log_path_text" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="12dp" android:background="@color/surface"
            android:fontFamily="monospace" android:textSize="10sp" android:textColor="@color/text_hint"
            android:layout_marginBottom="8dp"/>

        <!-- Permission instructions — updates based on current permission state -->
        <TextView android:id="@+id/permission_instructions" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="12dp" android:background="@color/surface"
            android:fontFamily="monospace" android:textSize="11sp" android:textColor="@color/text_dim"
            android:layout_marginBottom="4dp" android:visibility="gone"/>

        <Button android:id="@+id/btn_permission" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:backgroundTint="@color/green"
            android:textColor="#000000" android:fontFamily="monospace" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// MASTER SWITCH" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@color/surface" android:padding="16dp"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Enable notification reading"
                android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="monospace"/>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_enabled"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// VOICE COMMANDS" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@color/surface" android:padding="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Enable voice commands"
                    android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="monospace"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="&quot;Can you repeat?&quot;  &quot;How long ago?&quot;"
                    android:textColor="@color/text_muted" android:textSize="12sp" android:fontFamily="monospace"/>
            </LinearLayout>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_voice_commands"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <TextView android:id="@+id/voice_command_status" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="12dp" android:background="@color/surface"
            android:fontFamily="monospace" android:textSize="11sp" android:textColor="@color/status_inactive"
            android:layout_marginTop="3dp" android:layout_marginBottom="16dp"
            android:text="Voice commands: off"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// DEFAULT READ MODE" style="@style/SectionLabel"/>
        <Spinner android:id="@+id/spinner_read_mode" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="@color/surface"
            android:padding="12dp" android:layout_marginBottom="8dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@color/surface" android:padding="16dp"
            android:layout_marginBottom="20dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Always read app name"
                android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="monospace"/>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_read_app_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// DO NOT DISTURB" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@color/surface" android:padding="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Enable quiet hours"
                android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="monospace"/>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_dnd"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/layout_dnd" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:background="@color/surface" android:padding="16dp"
            android:layout_marginTop="3dp" android:visibility="gone">
            <TextView android:id="@+id/txt_dnd_start" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Silence from: 22:00"
                android:textColor="@color/text_dim" android:fontFamily="monospace" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_dnd_start" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:progressTint="@color/status_warning"
                android:thumbTint="@color/status_warning" android:layout_marginBottom="14dp"/>
            <TextView android:id="@+id/txt_dnd_end" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Until: 08:00"
                android:textColor="@color/text_dim" android:fontFamily="monospace" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_dnd_end" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:progressTint="@color/status_warning"
                android:thumbTint="@color/status_warning"/>
        </LinearLayout>

        <Button android:id="@+id/btn_stop" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="⏹  STOP SPEAKING"
            android:backgroundTint="@color/btn_danger_bg" android:textColor="@color/status_error"
            android:fontFamily="monospace" android:layout_marginTop="20dp"/>
    </LinearLayout>
</ScrollView>
