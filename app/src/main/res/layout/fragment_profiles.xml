<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#0d0d0d">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="VOICE PROFILES" android:textSize="20sp" android:textStyle="bold"
            android:textColor="#00ff88" android:fontFamily="monospace" android:layout_marginBottom="14dp"/>

        <!-- Profile selector -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// ACTIVE PROFILE" style="@style/SectionLabel"/>
        <Spinner android:id="@+id/spinner_profile" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="#111111"
            android:padding="12dp" android:layout_marginBottom="8dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="end" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btn_new_profile" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="+ NEW"
                android:backgroundTint="#1a2a1a" android:textColor="#00ff88"
                android:fontFamily="monospace" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btn_delete" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="DELETE"
                android:backgroundTint="#2a1a1a" android:textColor="#ff4444" android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Personality presets -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// PERSONALITY PRESETS" style="@style/SectionLabel"/>
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <LinearLayout android:id="@+id/layout_presets" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:orientation="horizontal"/>
        </HorizontalScrollView>

        <!-- Voice picker with filters -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// BASE VOICE" style="@style/SectionLabel"/>

        <LinearLayout android:id="@+id/gender_filter_row" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:layout_marginBottom="6dp"/>
        <LinearLayout android:id="@+id/nation_filter_row" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:layout_marginBottom="8dp"/>

        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <LinearLayout android:id="@+id/voice_grid" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:flexWrap="wrap"/>
        </HorizontalScrollView>

        <!-- Pitch & Speed -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// PITCH &amp; SPEED" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#111111" android:padding="16dp"
            android:layout_marginBottom="14dp">
            <TextView android:id="@+id/tv_pitch" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Pitch: 1.00"
                android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_pitch" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:progressTint="#00ff88" android:thumbTint="#00ff88" android:layout_marginBottom="14dp"/>
            <TextView android:id="@+id/tv_speed" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Speed: 1.00"
                android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_speed" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:progressTint="#00ff88" android:thumbTint="#00ff88"/>
        </LinearLayout>

        <!-- Breathiness -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// BREATHINESS" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#111111" android:padding="16dp" android:layout_marginBottom="14dp">
            <TextView android:id="@+id/tv_breath_int" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Intensity: 0" android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_breath_int" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:progressTint="#00ccff" android:thumbTint="#00ccff" android:layout_marginBottom="14dp"/>
            <TextView android:id="@+id/tv_breath_curve" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Curve: 0%" android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_breath_curve" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:progressTint="#00ccff" android:thumbTint="#00ccff" android:layout_marginBottom="14dp"/>
            <TextView android:id="@+id/tv_breath_pause" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Pause: 0" android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_breath_pause" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:progressTint="#00ccff" android:thumbTint="#00ccff"/>
        </LinearLayout>

        <!-- Stuttering -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// STUTTERING" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#111111" android:padding="16dp" android:layout_marginBottom="14dp">
            <TextView android:id="@+id/tv_stutter_int" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Intensity: 0" android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_stutter_int" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:progressTint="#ff88aa" android:thumbTint="#ff88aa" android:layout_marginBottom="14dp"/>
            <TextView android:id="@+id/tv_stutter_pos" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Position: 0%" android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_stutter_pos" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:progressTint="#ff88aa" android:thumbTint="#ff88aa" android:layout_marginBottom="14dp"/>
            <TextView android:id="@+id/tv_stutter_freq" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Frequency: 0%" android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_stutter_freq" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:progressTint="#ff88aa" android:thumbTint="#ff88aa" android:layout_marginBottom="14dp"/>
            <TextView android:id="@+id/tv_stutter_pause" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Pause: 30" android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_stutter_pause" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:progressTint="#ff88aa" android:thumbTint="#ff88aa"/>
        </LinearLayout>

        <!-- Intonation -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// INTONATION" style="@style/SectionLabel"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#111111" android:padding="16dp" android:layout_marginBottom="14dp">
            <TextView android:id="@+id/tv_intonation_int" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Intensity: 0" android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_intonation_int" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:progressTint="#ffcc00" android:thumbTint="#ffcc00" android:layout_marginBottom="14dp"/>
            <TextView android:id="@+id/tv_intonation_var" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Variation: 50%" android:textColor="#aaaaaa" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/seek_intonation_var" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:progressTint="#ffcc00" android:thumbTint="#ffcc00"/>
        </LinearLayout>

        <!-- Commentary pools -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// CONTEXTUAL COMMENTARY" style="@style/SectionLabel"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Lines said before/after the notification. Each pool fires only when its condition matches."
            android:textSize="11sp" android:textColor="#446644" android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:id="@+id/commentary_pools_container" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="6dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btn_add_pre_comment" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="+ BEFORE pool"
                android:backgroundTint="#1a3a2a" android:textColor="#00ff88"
                android:fontFamily="monospace" android:textSize="11sp" android:layout_marginEnd="6dp"/>
            <Button android:id="@+id/btn_add_post_comment" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="+ AFTER pool"
                android:backgroundTint="#1a2a3a" android:textColor="#00ccff"
                android:fontFamily="monospace" android:textSize="11sp"/>
        </LinearLayout>

        <!-- Gimmicks -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// GIMMICKS  (giggle · sigh · huh · mmm · woah · ugh · aww · gasp · yawn · hmm · laugh · tsk)"
            style="@style/SectionLabel"/>
        <LinearLayout android:id="@+id/gimmicks_container" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="16dp"/>

        <!-- Preview & Save -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// PREVIEW" style="@style/SectionLabel"/>
        <EditText android:id="@+id/txt_preview" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="#111111"
            android:textColor="#cccccc" android:fontFamily="monospace" android:textSize="13sp"
            android:padding="12dp" android:layout_marginBottom="10dp"
            android:text="Hello! This is how I sound with these settings."
            android:inputType="textMultiLine" android:minLines="2"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="24dp">
            <Button android:id="@+id/btn_test" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="▶ TEST"
                android:backgroundTint="#1a2a1a" android:textColor="#00ff88"
                android:fontFamily="monospace" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btn_save" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="💾 SAVE"
                android:backgroundTint="#1a1a2a" android:textColor="#8888ff" android:fontFamily="monospace"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
