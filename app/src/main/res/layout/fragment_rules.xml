<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg" android:padding="20dp">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="WORD RULES" android:textSize="20sp" android:textStyle="bold"
        android:textColor="@color/green" android:fontFamily="monospace" android:layout_marginBottom="6dp"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Replace words/phrases before they are spoken."
        android:textSize="12sp" android:textColor="@color/text_secondary" android:fontFamily="monospace"
        android:layout_marginBottom="12dp"/>
    <Button android:id="@+id/btn_add_rule" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="+ ADD RULE"
        android:backgroundTint="#1a2a1a" android:textColor="@color/green"
        android:fontFamily="monospace" android:layout_marginBottom="14dp"/>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:id="@+id/rules_container" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"/>
    </ScrollView>
</LinearLayout>
