<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="3dp">

    <!-- Top row: app label + toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:padding="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md_lg"
        android:paddingBottom="@dimen/spacing_md_lg">
        <TextView
            android:id="@+id/tv_app_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="@dimen/text_body"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif"/>
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_app_enabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Bottom row: mode + profile spinners (visible when enabled) -->
    <LinearLayout
        android:id="@+id/layout_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/row_bg"
        android:padding="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        android:visibility="gone">
        <Spinner
            android:id="@+id/spinner_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <Spinner
            android:id="@+id/spinner_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_force_local"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/local_only"
            android:textSize="@dimen/text_micro"
            android:paddingStart="@dimen/spacing_sm"/>
    </LinearLayout>
</LinearLayout>
