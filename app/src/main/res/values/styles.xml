<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowBackground">@color/bg</item>
    </style>
    <style name="SectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_section_label</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.2</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:layout_marginTop">4dp</item>
    </style>
    <style name="NavTab">
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
    </style>
    <style name="NavTabLabel">
        <item name="android:textSize">12sp</item>
    </style>
    <!-- L12: Standardized button styles -->
    <style name="KyokanButton">
        <item name="android:backgroundTint">@color/btn_primary_bg</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/text_body_sm</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
    </style>
    <style name="KyokanButton.Danger">
        <item name="android:backgroundTint">@color/btn_red_bg</item>
        <item name="android:textColor">@color/accent_red</item>
    </style>
    <style name="KyokanButton.Accent">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_on_accent</item>
    </style>
</resources>
